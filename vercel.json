{
  "version": 2,
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/push/cron?type=motivation",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/push/cron?type=evening",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/push/cron?type=weekly",
      "schedule": "0 15 * * 0"
    }
  ]
}
